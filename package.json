{
  "name": "@carlotrimarchi/nummerino",
  "version": "0.3.2",
  "type": "module",
  "license": "MIT",
  "bin": {
    "nummerino": "./dist/cli/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "npm run build:cli",
    "build:cli": "tsc -p tsconfig.cli.json",
    "cli": "npx --silent tsx src/cli/cli.ts",
